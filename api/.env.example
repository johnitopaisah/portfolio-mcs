# Copy to .env — never commit the real file
PORT=4000
NODE_ENV=development

# PostgreSQL — matches docker-compose service name "db"
DATABASE_URL=postgres://portfolio_user:changeme@db:5432/portfolio

# JWT — use a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-very-long-random-string
JWT_EXPIRES_IN=20m

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://johnisah.com,https://admin.johnisah.com
