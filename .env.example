# ============================================================
#  Portfolio MCS — Local environment template
#  cp .env.example .env   then fill in every value
#  NEVER commit .env to git — it is gitignored
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=           # your DB password — no default in docker-compose

# ── Admin account ────────────────────────────────────────────
# bcrypt hash of your admin panel password (cost factor 12)
# Generate:
#   docker run --rm node:20-alpine \
#     sh -c "npm i -q bcryptjs && node -e \
#     \"require('bcryptjs').hash('YourPassword',12).then(console.log)\""
ADMIN_PASSWORD_HASH=         # e.g. $2b$12$...

# ── Admin profile (seeded into DB on first start) ────────────
ADMIN_PROFILE_NAME=John Itopa ISAH
ADMIN_PROFILE_HEADLINE=DevOps & Cloud Engineer
ADMIN_PROFILE_BIO=Engineering graduate specialising in cloud infrastructure, Kubernetes, and scalable distributed systems.
ADMIN_PROFILE_EMAIL=         # your contact email shown on portfolio
ADMIN_PROFILE_GITHUB=        # https://github.com/yourhandle
ADMIN_PROFILE_LINKEDIN=      # https://linkedin.com/in/yourhandle

# ── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=                  # long random hex string (64+ chars)
JWT_EXPIRES_IN=1h         # e.g. 7d, 24h — how long admin sessions last

# ── Admin UI base URL ────────────────────────────────────────
# Used to build password reset links in notification emails
# Local:      http://localhost:3001
# Production: https://admin.johnisah.com
ADMIN_URL=http://localhost:3001

# ── Email notifications (Gmail SMTP) ─────────────────────────
# Use a Gmail App Password — NOT your real Gmail password
# Generate at: myaccount.google.com → Security → App Passwords
NOTIFY_EMAIL_USER=           # gmail address that owns the App Password
NOTIFY_EMAIL_PASS=           # 16-char App Password (xxxx xxxx xxxx xxxx)
NOTIFY_EMAIL_TO=             # your personal inbox for notifications

# ── SMS notifications (Twilio) ───────────────────────────────
# Sign up free at twilio.com — trial gives ~150 SMS
TWILIO_ACCOUNT_SID=          # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=           # your Twilio auth token
TWILIO_FROM=                 # your Twilio phone number e.g. +13187688357
TWILIO_TO=                   # your personal phone
